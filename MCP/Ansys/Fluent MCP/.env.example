# Optional. If unset, the tools try ANSYS_ROOT, AWP_ROOT*, and common install paths.
ANSYS_ROOT=C:\Program Files\ANSYS Inc\v261
FLUENT_EXE=C:\Program Files\ANSYS Inc\v261\fluent\ntbin\win64\fluent.exe
FLUENT_VERSION=26.1

# Local MCP runtime folder. Generated job metadata and logs are not committed.
FLUENT_MCP_JOBS_DIR=.\jobs

# PyFluent launch defaults used by fluent_launch_session_tool.
PYFLUENT_LAUNCH_MODE=solver
PYFLUENT_UI_MODE=hidden_gui
PYFLUENT_DIMENSION=3
PYFLUENT_PRECISION=double
PYFLUENT_PROCESSOR_COUNT=2
