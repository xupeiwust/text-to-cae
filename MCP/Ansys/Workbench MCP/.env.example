# Optional. If unset, the tools try ANSYS_ROOT, AWP_ROOT*, and common install paths.
ANSYS_ROOT=C:\Program Files\ANSYS Inc\v261
ANSYS_WB_EXE=C:\Program Files\ANSYS Inc\v261\Framework\bin\Win64\RunWB2.exe

# Optional PyMechanical CLI override. If unset, .venv\Scripts\ansys-mechanical.exe is used.
ANSYS_MECHANICAL_CLI=

# Local MCP runtime folders. These are generated at runtime and should not be committed.
JOBS_DIR=.\jobs
WORKBENCH_MCP_ROOT=.
WORKBENCH_MCP_QUEUE_ROOT=.\workbench_queue

# Mechanical socket timer bridge.
WORKBENCH_MCP_HOST=127.0.0.1
WORKBENCH_MCP_PORT=9885
WORKBENCH_MCP_AUTO_START_SOCKET=1
WORKBENCH_MCP_AUTO_START_QUEUE=1
WORKBENCH_MCP_QUEUE_INTERVAL_MS=1500
