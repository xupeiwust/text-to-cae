<?xml version="1.0" encoding="utf-8"?>
<extension version="2026" minorversion="1" name="WorkbenchMCP" loadAsDefault="true">
  <guid shortid="WorkbenchMCP">9f2d1d85-97a3-4e23-82f7-c7a8d25a2f31</guid>
  <author>Text-to-CAE</author>
  <description>MCP queue and socket bridge for ANSYS Mechanical.</description>
  <script src="main.py" />
  <interface context="Mechanical">
    <toolbar name="Workbench MCP" caption="Workbench MCP">
      <entry name="Process MCP Queue">
        <callbacks>
          <onclick>process_mcp_queue</onclick>
        </callbacks>
      </entry>
      <entry name="Queue Info">
        <callbacks>
          <onclick>show_mcp_queue_info</onclick>
        </callbacks>
      </entry>
      <entry name="Socket Timer Start">
        <callbacks>
          <onclick>start_mcp_socket_timer</onclick>
        </callbacks>
      </entry>
      <entry name="Socket Timer Stop">
        <callbacks>
          <onclick>stop_mcp_socket_timer</onclick>
        </callbacks>
      </entry>
    </toolbar>
  </interface>
</extension>
