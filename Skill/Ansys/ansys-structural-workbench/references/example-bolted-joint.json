{
  "schema_version": "1.1",
  "task_name": "BOLTED_LAP_JOINT_V1",
  "analysis_profiles": ["nonlinear_static", "contact", "bolt_pretension"],
  "model": {
    "source": "import_cad",
    "cad_path": "BOLTED_LAP_JOINT_V1.step",
    "overwrite": false,
    "units": {"length": "mm", "force": "N", "stress": "MPa"}
  },
  "materials": [{"name": "STEEL", "model": "linear_elastic", "youngs_modulus": 210000, "poissons_ratio": 0.3}],
  "connections": [{"name": "PLATE_INTERFACE", "type": "frictional", "friction_coefficient": 0.15}],
  "bolt_pretensions": [
    {
      "name": "PRETENSION_BOLT_1",
      "section_scope": "NS_BOLT_1_PRETENSION_SECTION",
      "step_table": [{"step": 1, "state": "apply", "force": 25000}, {"step": 2, "state": "lock"}]
    }
  ],
  "supports": [{"name": "FIXED_END", "type": "fixed"}],
  "loads": [{"name": "SERVICE_SHEAR", "type": "force", "step_values": [[1, 0], [2, 30000]], "unit": "N"}],
  "solution": {"number_of_steps": 2, "automatic_time_stepping": true, "large_deflection": false},
  "mesh": {
    "profile": "solid_contact",
    "element_order": "quadratic",
    "method_policy": {"prefer": ["sweep", "multizone"], "fallback": "patch_conforming_tetra"},
    "convergence": {
      "enabled": true,
      "levels": [{"name": "M1"}, {"name": "M2"}, {"name": "M3"}],
      "metrics": [{"name": "joint_slip", "tolerance_percent": 3.0}]
    }
  },
  "validation": {"force_balance_tolerance_percent": 0.5},
  "outputs": ["bolt_working_load", "pretension_adjustment", "contact_status", "sliding_distance", "analysis_report"]
}
